# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Site URL (used for OAuth and magic link redirects)
# Local: http://localhost:3000
# Production: https://your-deployed-domain.vercel.app
NEXT_PUBLIC_SITE_URL=https://your-deployed-domain.vercel.app

# Google OAuth (configure in Supabase Dashboard > Auth > Providers > Google)
# GOOGLE_CLIENT_ID=<your-google-client-id>
# GOOGLE_CLIENT_SECRET=<your-google-client-secret>
